// This is the proposed PostgreSQL Prisma schema for Neqta database migration
// It introduces native PostgreSQL enums, Json fields, text arrays, and all requested extensions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums (Supported natively in PostgreSQL)
// ----------------------------------------------------------------------------

enum Plan {
  STARTER
  PRO
  ENTERPRISE
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  AGENT
  VIEWER
}

enum PlatformType {
  FACEBOOK_PAGE
  INSTAGRAM
  WHATSAPP
}

enum TriggerType {
  KEYWORD
  ANY_COMMENT
  STORY_MENTION
}

enum MatchType {
  EXACT
  CONTAINS
  AI_SEMANTIC
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  COMMENT
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  FAILED
  CANCELLED
}

// ----------------------------------------------------------------------------
// Core Identity & Multi-tenancy
// ----------------------------------------------------------------------------

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  name                String?
  password            String?              // Nullable if using OAuth
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  memberships         TenantMember[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
}

model Tenant {
  id            String                 @id @default(uuid())
  name          String
  plan          Plan                   @default(STARTER)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  members       TenantMember[]
  connections   PlatformConnection[]
  rules         AutoReplyRule[]
  conversations Conversation[]
  campaigns     Campaign[]
  auditLogs     AuditLog[]
  webhooks      WebhookDeduplication[]
  flows         Flow[]
  flowExecutions FlowExecution[]
  customRoles   CustomRole[]
}

model TenantMember {
  id        String      @id @default(uuid())
  userId    String
  tenantId  String
  role      TenantRole  @default(MEMBER)
  roleId    String?     // Nullable link to custom roles for granular RBAC

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, tenantId])
}

model CustomRole {
  id          String         @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions String[]       // PostgreSQL native text array

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members     TenantMember[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, name])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

// ----------------------------------------------------------------------------
// Social Media Connections
// ----------------------------------------------------------------------------

model PlatformConnection {
  id            String             @id @default(uuid())
  tenantId      String
  platform      PlatformType
  platformId    String             // Page ID, IG Account ID, Phone Number ID
  name          String             // Page Name or Number
  accessToken   String?            // Encrypted token or System User Token
  isActive      Boolean            @default(true)
  
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules         AutoReplyRule[]
  conversations Conversation[]
  campaigns     Campaign[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([platform, platformId])
}

// ----------------------------------------------------------------------------
// Automation Rules
// ----------------------------------------------------------------------------

model AutoReplyRule {
  id            String              @id @default(uuid())
  tenantId      String
  connectionId  String?             // If null, applies to all connections of this tenant
  postId        String?             // If null, applies globally. If set, applies only to this specific post
  name          String
  triggerType   TriggerType
  keywords      String              // Comma separated keywords
  matchType     MatchType           @default(EXACT)
  
  replyText     String?             // Public text reply to comment
  replyMedia    Json?               // PostgreSQL JSON representing media URLs (images/videos)
  privateText   String?             // Private text DM to send
  privateMedia  Json?               // PostgreSQL JSON representing media URLs (images/videos)
  
  priority      Int                 @default(0) // Higher number = higher priority
  isActive      Boolean             @default(true)

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection    PlatformConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

// ----------------------------------------------------------------------------
// Unified Inbox
// ----------------------------------------------------------------------------

model Conversation {
  id            String             @id @default(uuid())
  tenantId      String
  connectionId  String
  customerName  String
  customerId    String             // PSID (Page-Scoped ID) or WhatsApp Number
  lastMessageAt DateTime           @default(now())
  status        ConversationStatus @default(OPEN)

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection    PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  messages      Message[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([connectionId, customerId])
}

model Message {
  id             String           @id @default(uuid())
  conversationId String
  direction      MessageDirection
  content        String
  messageType    MessageType      @default(TEXT)
  metaData       Json?            // Native PostgreSQL JSON representing original payload

  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime         @default(now())
}

// ----------------------------------------------------------------------------
// Webhook Deduplication
// ----------------------------------------------------------------------------

model WebhookDeduplication {
  id          String   @id @default(uuid())
  eventId     String   @unique // External event ID (e.g. WhatsApp msg ID, Facebook entry ID + time)
  platform    String   // e.g. "FACEBOOK", "WHATSAPP", "INSTAGRAM"
  tenantId    String?
  processedAt DateTime @default(now())
  status      String   @default("PROCESSING") // PROCESSING, PROCESSED, FAILED
  expiresAt   DateTime // Expiration timestamp for database pruning (e.g., now + 48 hours)

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

// ----------------------------------------------------------------------------
// Broadcasts / Campaign Management
// ----------------------------------------------------------------------------

model Campaign {
  id           String             @id @default(uuid())
  tenantId     String
  connectionId String
  name         String
  description  String?
  status       CampaignStatus     @default(DRAFT)
  content      String
  mediaUrl     Json?              // PostgreSQL JSON representing media (images/videos)
  scheduledAt  DateTime?          // Scheduled start time
  sentAt       DateTime?          // Execution complete time
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection   PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  recipients   CampaignRecipient[]
}

model CampaignRecipient {
  id           String    @id @default(uuid())
  campaignId   String
  customerId   String    // PSID or WhatsApp Number
  customerName String?
  status       String    @default("PENDING") // PENDING, SENT, DELIVERED, READ, FAILED
  errorMessage String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?

  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerId])
}

// ----------------------------------------------------------------------------
// Audit Logging
// ----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String   // e.g. "CAMPAIGN_CREATED", "RULE_UPDATED", "USER_LOGIN"
  entityType String   // e.g. "Campaign", "AutoReplyRule", "PlatformConnection"
  entityId   String?  // ID of the target record
  oldValues  Json?    // Native PostgreSQL JSON representing state before change
  newValues  Json?    // Native PostgreSQL JSON representing state after change
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

// ----------------------------------------------------------------------------
// Flow Automation Engine
// ----------------------------------------------------------------------------

model Flow {
  id          String          @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  triggers    FlowTrigger[]
  steps       FlowStep[]
  executions  FlowExecution[]
}

model FlowTrigger {
  id            String   @id @default(uuid())
  flowId        String
  type          String   // e.g. "INCOMING_MESSAGE", "ANY_COMMENT", "CONTACT_TAGGED"
  configuration Json?    // Filtering/trigger criteria (e.g. keywords, page IDs)

  flow          Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

model FlowStep {
  id            String       @id @default(uuid())
  flowId        String
  type          String       // e.g. "SEND_MESSAGE", "WAIT_DELAY", "CONDITIONAL_BRANCH", "ADD_TAG"
  configuration Json         // Node actions configuration (text payload, delays, rules)
  metadata      Json?        // Coordinates and editor metadata for UI builders

  flow          Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  branches      FlowBranch[]
}

model FlowBranch {
  id          String    @id @default(uuid())
  stepId      String
  label       String    // e.g. "Yes", "No", "Default"
  condition   Json?     // Branch matching rules
  nextStepId  String?   // FlowStep ID to execute if matched

  step        FlowStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model FlowExecution {
  id            String             @id @default(uuid())
  flowId        String
  tenantId      String
  customerId    String             // Recipient PSID or Phone Number
  status        String             @default("RUNNING") // RUNNING, COMPLETED, FAILED, PAUSED
  currentStepId String?
  variables     Json?              // Context values gathered during execution
  pausedUntil   DateTime?          // Used to track delay execution wakeup
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  flow          Flow               @relation(fields: [flowId], references: [id], onDelete: Cascade)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs          FlowExecutionLog[]
}

model FlowExecutionLog {
  id          String        @id @default(uuid())
  executionId String
  stepId      String?
  stepType    String?
  executedAt  DateTime      @default(now())
  status      String        // SUCCESS, FAILED
  error       String?

  execution   FlowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
}
