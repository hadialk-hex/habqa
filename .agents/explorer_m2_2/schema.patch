 // ----------------------------------------------------------------------------
 // Social Media Connections
 // ----------------------------------------------------------------------------
 
-// Enums are not supported in SQLite, use String instead.
+enum PlatformType {
+  FACEBOOK_PAGE
+  INSTAGRAM
+  WHATSAPP
+}
 
 model PlatformConnection {
   id            String       @id @default(uuid())
   tenantId      String
-  platform      String       // FACEBOOK_PAGE, INSTAGRAM, WHATSAPP
+  platform      PlatformType
   platformId    String       // Page ID, IG Account ID, Phone Number ID
   name          String       // Page Name or Number
   accessToken   String?      // Encrypted token or System User Token
   isActive      Boolean      @default(true)
   
   tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
   rules         AutoReplyRule[]
   conversations Conversation[]
 
   createdAt     DateTime     @default(now())
   updatedAt     DateTime     @updatedAt
 
   @@unique([platform, platformId])
+  @@index([tenantId])
