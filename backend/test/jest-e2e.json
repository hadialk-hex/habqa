{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "globalSetup": "<rootDir>/global-setup.ts",
  "setupFiles": ["<rootDir>/setup.ts"],
  "moduleNameMapper": {
    "^generic-pool$": "<rootDir>/../node_modules/generic-pool"
  }
}
