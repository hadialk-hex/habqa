# ═══════════════════════════════════════════════════════════════
# Hubqa (حبقة) — Environment Variables
# Copy this file to .env and fill in real values before running.
# ═══════════════════════════════════════════════════════════════

# ──── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/hubqa?schema=public

# ──── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ──── JWT & Security ──────────────────────────────────────────
# Use a strong random secret: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_RANDOM_32_HEX_CHARS

# AES-256 encryption key for platform access tokens: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_USE_RANDOM_32_CHARS

# HMAC signing key for the Facebook/Instagram OAuth "state" param (CSRF
# protection on the connect flow). Independent of FACEBOOK_APP_SECRET —
# generate with: openssl rand -hex 32
APP_SECRET=CHANGE_ME_USE_RANDOM_32_HEX_CHARS

# ──── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:1998

# ──── Facebook App Credentials ────────────────────────────────
# Get these from https://developers.facebook.com/apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/dashboard/channels

# ──── Instagram App Credentials (Business Login) ──────────────
# Can reuse Facebook App ID/Secret or use a separate app
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/dashboard/channels

# ──── Webhook ──────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=hubqa_your_random_verify_token_here

# ──── Redis (optional — enables caching and job queues) ───────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ──── Email (SMTP — optional but needed for password reset) ───
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your@email.com
# MAIL_PASS=your_app_password
# MAIL_FROM="Hubqa <noreply@hubqa.com>"

# ──── AI (optional — enables AI-powered replies) ──────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ──── Frontend URL (for email links, OAuth callbacks) ─────────
FRONTEND_URL=http://localhost:3000
