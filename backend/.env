# ===== SMTP (لإرسال البريد: استعادة كلمة المرور ودعوات الفريق) =====
# مثال مع Gmail: SMTP_HOST=smtp.gmail.com و SMTP_PASS=App Password من إعدادات غوغل
# أو استخدم Resend: SMTP_HOST=smtp.resend.com, SMTP_USER=resend, SMTP_PASS=API Key
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="حبقة Hubqa <no-reply@yourdomain.com>"

# ===== Anthropic Claude (لميزة الردود الذكية AI) =====
# احصل على المفتاح من platform.claude.com ← API Keys
# ANTHROPIC_API_KEY="sk-ant-..."

# ===== Facebook / Meta (مطلوب للربط الحقيقي) =====
# أنشئ تطبيق Business على developers.facebook.com وحط القيم هنا.
# FACEBOOK_APP_ID="ضع رقم التطبيق"
# FACEBOOK_APP_SECRET="ضع سر التطبيق"
# FACEBOOK_REDIRECT_URI="https://نطاقك/channels/facebook/callback"
# WEBHOOK_VERIFY_TOKEN="كلمة-سرية-تختارها-لتحقق-الويبهوك"
